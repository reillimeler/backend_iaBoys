{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./",             // CAMBIO: Ahora la raíz es el proyecto entero
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "include": [
    "src/**/*",
    "prisma.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}